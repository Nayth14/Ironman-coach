# Copy this file to .env and fill in your key. Never commit .env.
OPENAI_API_KEY=sk-...

# Model selection (optional overrides)
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EXTRACT_MODEL=gpt-4o
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Supabase (optional — falls back to local SQLite when unset)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# JWT verification for protected API routes (Project Settings → API → JWT Secret)
# When unset, API accepts unsigned dev tokens for local testing
SUPABASE_JWT_SECRET=your-jwt-secret

# API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
